# Copy to .env.local and fill in values (never commit .env.local)

# LlamaParse
# VITE_LLAMAPARSE_API_KEY=
# VITE_LLAMA_CLOUD_API_KEY=

# Google Document AI
# VITE_GOOGLE_DOCAI_PROJECT=my-gcp-project
# VITE_GOOGLE_DOCAI_LOCATION=us
# VITE_GOOGLE_DOCAI_PROCESSOR=processor-id
# VITE_GOOGLE_DOCAI_TOKEN=ya29....   # gcloud auth print-access-token
# VITE_GOOGLE_ACCESS_TOKEN=ya29....

# Optional AI toolkit / remote engine
# VITE_TOOLKIT_URL=
# VITE_REMOTE_ENGINE_URL=

# Optional visual
# VITE_APPLITOOLS_API_KEY=
